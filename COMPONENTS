import React, { useRef, useState } from 'react';

interface UploadStepProps {
  onFileSelected: (dataUri: string, fileName: string, fileType: string) => void;
}

const UploadStep: React.FC<UploadStepProps> = ({ onFileSelected }) => {
  const [isDragging, setIsDragging] = useState(false);
  const fileInputRef = useRef<HTMLInputElement>(null);

  const handleFile = (file: File) => {
    if (file) {
      const reader = new FileReader();
      reader.onload = (e) => {
        if (e.target?.result) {
          onFileSelected(e.target.result as string, file.name, file.type);
        }
      };
      reader.readAsDataURL(file);
    }
  };

  const onDragOver = (e: React.DragEvent) => {
    e.preventDefault();
    setIsDragging(true);
  };

  const onDragLeave = () => {
    setIsDragging(false);
  };

  const onDrop = (e: React.DragEvent) => {
    e.preventDefault();
    setIsDragging(false);
    const files = e.dataTransfer.files;
    if (files.length > 0) {
      handleFile(files[0]);
    }
  };

  return (
    <div className="flex-1 flex flex-col justify-center items-center text-center animate-in fade-in zoom-in duration-500">
      <div className="mb-10 space-y-4">
        <div className="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-red-900/30 border border-red-500/30 text-red-400 text-[10px] font-bold uppercase tracking-widest mb-2 shadow-sm">
           <i className="fas fa-bolt text-red-500"></i>
           Fast & Reliable
        </div>
        <h2 className="text-5xl md:text-7xl font-extrabold text-white tracking-tight leading-tight">
          Print Your <br/>
          <span className="text-transparent bg-clip-text bg-gradient-to-r from-red-500 to-orange-500">Documents</span>
        </h2>
        <p className="text-slate-300 text-lg max-w-md mx-auto leading-relaxed font-medium">
          Upload images or documents for high-quality printing.<br/>Supports PDF, PPT, JPG, and PNG.
        </p>
      </div>

      <div 
        onDragOver={onDragOver}
        onDragLeave={onDragLeave}
        onDrop={onDrop}
        onClick={() => fileInputRef.current?.click()}
        className={`w-full max-w-2xl aspect-[2.2/1] rounded-[2rem] border-2 border-dashed transition-all duration-300 flex flex-col items-center justify-center cursor-pointer relative overflow-hidden group shadow-sm
          ${isDragging 
            ? 'border-red-500 bg-red-500/10' 
            : 'border-slate-700 bg-white/5 hover:border-red-400 hover:bg-white/10'
          }`}
      >
        <div className={`absolute inset-0 bg-gradient-to-tr from-red-500/10 via-transparent to-orange-500/10 opacity-0 group-hover:opacity-100 transition-opacity duration-700`}></div>
        
        <div className="relative z-10 flex flex-col items-center">
            <div className={`w-20 h-20 rounded-full flex items-center justify-center mb-6 transition-all duration-300 shadow-xl
                ${isDragging ? 'bg-red-600 scale-110 rotate-12' : 'bg-slate-800 border border-slate-600 group-hover:border-red-400 group-hover:scale-105 group-hover:shadow-red-500/20'}`}>
              <i className={`fas ${isDragging ? 'fa-file-arrow-up text-white' : 'fa-cloud-arrow-up text-red-500'} text-3xl transition-colors`}></i>
            </div>
            <p className="text-xl font-bold text-white mb-2">Tap to Upload</p>
            <p className="text-sm text-slate-400 font-medium bg-black/30 px-3 py-1 rounded-full border border-white/10">
                PDF • DOCX • PPTX • IMG
            </p>
        </div>

        <input 
          type="file" 
          ref={fileInputRef} 
          className="hidden" 
          accept="image/*,.pdf,.ppt,.pptx"
          onChange={(e) => e.target.files && handleFile(e.target.files[0])}
        />
      </div>

      <div className="mt-12 flex items-center justify-center gap-10">
        {[
            { icon: 'fa-file-pdf', label: 'Documents', hover: 'group-hover:text-red-400', bg: 'group-hover:bg-red-900/20', border: 'group-hover:border-red-500/30' },
            { icon: 'fa-file-powerpoint', label: 'Slides', hover: 'group-hover:text-orange-400', bg: 'group-hover:bg-orange-900/20', border: 'group-hover:border-orange-500/30' },
            { icon: 'fa-image', label: 'Images', hover: 'group-hover:text-blue-400', bg: 'group-hover:bg-blue-900/20', border: 'group-hover:border-blue-500/30' }
        ].map(item => (
            <div key={item.label} className="flex flex-col items-center gap-3 group cursor-default">
