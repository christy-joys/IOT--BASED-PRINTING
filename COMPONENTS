import React, { useState, useEffect } from 'react';

interface PrintingStepProps {
  onComplete: () => void;
}

const PrintingStep: React.FC<PrintingStepProps> = ({ onComplete }) => {
  const [progress, setProgress] = useState(0);
  const [statusText, setStatusText] = useState('Initializing...');

  useEffect(() => {
    const statuses = [
      { p: 10, text: 'Connecting to printer...' },
      { p: 25, text: 'Warming up fuser...' },
      { p: 40, text: 'Feeding paper...' },
      { p: 55, text: 'Processing document...' },
      { p: 70, text: 'Printing page 1...' },
      { p: 85, text: 'Finalizing print...' },
      { p: 95, text: 'Ejecting to tray...' },
      { p: 100, text: 'Done.' },
    ];

    const interval = setInterval(() => {
      setProgress(prev => {
        const next = prev + 1;
        
        const currentStatus = statuses.find(s => next <= s.p);
        if (currentStatus) setStatusText(currentStatus.text);

        if (next >= 100) {
          clearInterval(interval);
          setTimeout(onComplete, 1000);
          return 100;
        }
        return next;
      });
    }, 60);

    return () => clearInterval(interval);
  }, [onComplete]);

  return (
    <div className="flex-1 flex flex-col items-center justify-center text-center animate-in fade-in duration-1000">
      <div className="relative mb-16">
        {/* Printer Animation */}
        <div className="w-64 h-40 relative mx-auto">
             {/* Paper */}
             <div className="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-full bg-white rounded-t-lg shadow-sm border border-slate-100 transition-all duration-100"
                  style={{ transform: `translate(-50%, ${-40 + (progress * 0.4)}%)` }}
             >
                <div className="p-4 space-y-2 opacity-50">
                    <div className="h-2 w-3/4 bg-slate-200 rounded"></div>
                    <div className="h-2 w-full bg-slate-200 rounded"></div>
                    <div className="h-2 w-5/6 bg-slate-200 rounded"></div>
                </div>
             </div>

             {/* Printer Body */}
             <div className="absolute bottom-0 left-0 right-0 h-24 bg-slate-800 rounded-2xl border border-slate-700 z-10 shadow-2xl flex items-center justify-center">
                 <div className="w-full h-1 bg-black/50 absolute top-0"></div>
                 <div className="w-12 h-1 rounded-full bg-red-500 animate-pulse shadow-[0_0_15px_rgba(239,68,68,0.6)]"></div>
             </div>
        </div>
      </div>

      <div className="max-w-md w-full px-8">
        <h2 className="text-2xl font-bold mb-2 tracking-tight text-white">Printing...</h2>
        <p className="text-slate-400 mb-8 text-sm font-medium">{statusText}</p>
        
        <div className="w-full bg-slate-800 h-2 rounded-full overflow-hidden relative">
          <div 
            className="h-full bg-gradient-to-r from-red-600 to-orange-600 transition-all duration-100 ease-out shadow-[0_0_10px_rgba(220,38,38,0.5)]"
